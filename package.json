{
  "name": "survivor-fantasy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint src/",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:test": "tsx prisma/seed-test.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "sim:export": "Rscript src/simulation/data/export-survivor-data.R",
    "sim:import": "tsx src/simulation/data/import.ts",
    "sim:run": "tsx src/simulation/cli/simulate.ts",
    "sim:batch": "tsx src/simulation/cli/batch.ts",
    "sim:compare": "tsx src/simulation/cli/compare.ts",
    "sim:preview": "tsx src/simulation/cli/preview.ts",
    "snap": "tsx scripts/db-snapshot.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@serwist/next": "^9.5.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eruda": "^3.4.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "pg": "^8.13.0",
    "prisma": "^7.5.0",
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "react-easy-crop": "^5.5.6",
    "recharts": "^3.7.0",
    "serwist": "^9.5.7",
    "svix": "^1.84.1",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clerk/testing": "^1.13.35",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.3",
    "@eslint/eslintrc": "^3.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.0.0",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "prisma",
      "esbuild",
      "unrs-resolver"
    ]
  }
