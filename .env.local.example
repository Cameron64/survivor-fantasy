# Local Development Environment Variables
# Copy this file to .env.local and fill in your values

# Local database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/survivor_fantasy_local"

# Production database (optional - only needed for "Pull Production Data" dev tool)
# This allows you to import fresh production data into your local database
PROD_DATABASE_URL="postgresql://user:password@host:5432/survivor_fantasy_prod"

# Clerk Auth (required)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# App URL (optional)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Slack webhook (optional)
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
